		<material name="rubberduck_mat" texture="rubberduck_tex" />

		

	</asset>
	<worldbody>
		<geom name="floor" size="0 0 0.01" type="plane" material="groundplane" contype="1" conaffinity="0" priority="1"
		  friction="0.6" condim="3"/>
	
			<light diffuse=".5 .5 .5" pos="-3 -3 5" dir="3 3 -5" castshadow="true"/>
		
		
			
			<body name="Cylinder_001" pos="1.000000 1.000000 0.000000" quat="1.00000000 0.00000000 0.00000000 0.00000000">
				<geom type="mesh" mesh="Cylinder_001" material="Cylinder_001_mat" contype="0" conaffinity="0" group="1" />
				<geom type="mesh" mesh="Cylinder_001_col" group="3" contype="1" conaffinity="1" friction="0.8 0.005 0.0001" />
			</body>
			<body name="rubberduck" pos="1.000000 1.000000 0.641339" quat="1.00000000 0.00000000 0.00000000 0.00000000">
				<freejoint name="rubberduck_free" />
				<inertial pos="0 0 0" mass="0.10" diaginertia="0.0005 0.0005 0.0005" />
				<geom type="mesh" mesh="rubberduck" material="rubberduck_mat" contype="0" conaffinity="0" group="1" />
				<geom type="mesh" mesh="rubberduck" group="3" contype="1" conaffinity="1" friction="0.6 0.005 0.0001" density="700" />
			</body>
			

	</worldbody>
	<option timestep="0.0005" solver="Newton" iterations="200" ls_iterations="100"/>
